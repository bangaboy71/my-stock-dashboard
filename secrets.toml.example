# .streamlit/secrets.toml — Streamlit Cloud 배포 설정
# ─────────────────────────────────────────────────────────────────
# Streamlit Cloud → Manage app → Settings → Secrets 에 붙여넣기
# 로컬 실행 시: .streamlit/secrets.toml 파일로 저장
#
# ⚠️ 절대 GitHub에 커밋하지 마세요 (.gitignore에 추가 필수)
# ─────────────────────────────────────────────────────────────────

# ── 구글 시트 연결 (기존 설정 유지) ─────────────────────────────
[connections.gsheets]
spreadsheet    = "https://docs.google.com/spreadsheets/d/1foODSvPSl8FoRcrSJFz4RqNBu5uJU_2rRz0cGTFrklc"
type           = "st.connections.ExperimentalBaseConnection"
# 서비스 계정 키는 아래 형식으로 추가
# private_key_id = "..."
# private_key    = "-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
# client_email   = "...@...iam.gserviceaccount.com"
# token_uri      = "https://oauth2.googleapis.com/token"


# ── 앱 설정 ─────────────────────────────────────────────────────
[app]
# KOSPI 상대 수익률 비교 기준일 (변경 시 이 값만 수정)
kospi_base_date = "2026-03-03"


# ── 날짜별 팩트 스냅샷 (선택) ────────────────────────────────────
# 구글 시트 snapshot 워크시트가 있으면 시트가 우선 적용됩니다.
# 시트 없이 secrets만으로 운영할 때 사용합니다.
#
# [snapshots."2026-03-09"]
# KOSPI                        = 5251.87
# 삼성전자                     = 111400.0
# KODEX200타겟위클리커버드콜   = 16515.0
